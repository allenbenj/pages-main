  <body>
    <outline text="Evidence Network Analysis: Benjamin Allen Case">
      <outline text="Medical &amp; Forensic Evidence">
        <outline text="SANE Findings">
          <outline text="Abnormal dye uptake at posterior fourchette">
          </outline>
          <outline text="Normal labia minora, hymen, and vagina">
          </outline>
          <outline text="No visible lacerations or discharge">
          </outline>
          <outline text="Cervical ectropion (non-assault related)">
          </outline>
        </outline>
        <outline text="DNA &amp; Laboratory Results">
          <outline text="No spermatozoa present in SBI report">
          </outline>
          <outline text="ALS black light exam negative for fluorescence">
          </outline>
          <outline text="YSTR DNA cannot individuate defendant">
          </outline>
          <outline text="Insufficient male DNA for STR amplification">
          </outline>
        </outline>
        <outline text="Pre-existing Conditions">
          <outline text="Hidradenitis suppurativa (HS) in external areas">
          </outline>
          <outline text="Patient disclosed redness but not HS diagnosis">
          </outline>
        </outline>
      </outline>
      <outline text="Complainant Testimony Evolution">
        <outline text="Initial Accounts (Active Resistance)">
          <outline text="Triage: &apos;I pushed him off of me and I ran&apos;">
          </outline>
          <outline text="SANE: Narrative of physical escape">
          </outline>
          <outline text="Haines: &apos;I did everything I could to get away&apos;">
          </outline>
        </outline>
        <outline text="Trial Account (Passive Response)">
          <outline text="Introduction of &apos;tonic freeze&apos; narrative">
          </outline>
          <outline text="Claimed inability to move or comprehend">
          </outline>
          <outline text="Alleged coaching in courthouse lobby">
          </outline>
        </outline>
        <outline text="Mental Injury &amp; Impact">
          <outline text="Post-assault functional impairment">
          </outline>
          <outline text="Loss of trust and identification of triggers">
          </outline>
          <outline text="Relocation to different state">
          </outline>
        </outline>
      </outline>
      <outline text="Investigative Conduct &amp; Gaps">
        <outline text="Detective Freeman Issues">
          <outline text="Undisclosed relationship to witness Carmen Love">
          </outline>
          <outline text="False denial of ties to Morrison and West">
          </outline>
          <outline text="Inaccurate probable cause affidavit timestamps">
          </outline>
        </outline>
        <outline text="Officer Haines Issues">
          <outline text="Premature commitment to prosecute">
          </outline>
          <outline text="Failure to interview daughter present at home">
          </outline>
          <outline text="Did not inquire about consent during interview">
          </outline>
        </outline>
        <outline text="Procedural Failures">
          <outline text="Warrantless arrest without documented cause">
          </outline>
          <outline text="Blank witnesses field on Magistrate Order">
          </outline>
        </outline>
      </outline>
      <outline text="Timeline &amp; Physical Impossibilities">
        <outline text="Video Evidence Contradictions">
          <outline text="Carmen Love left 1 hour before 2:00 AM claim">
          </outline>
          <outline text="38-minute window from bar to hospital arrival">
          </outline>
          <outline text="Insufficient time for drive, assault, and escape">
          </outline>
        </outline>
        <outline text="Scene Reconstruction Issues">
          <outline text="Disputed bonfire location (front vs. back yard)">
          </outline>
          <outline text="Availability of three alternative house exits">
          </outline>
          <outline text="Hiding at airfield vs. bushes/woods">
          </outline>
        </outline>
      </outline>
      <outline text="Legal Motions &amp; Verdicts">
        <outline text="Franks &amp; Suppression">
          <outline text="Challenge to reckless disregard for truth">
          </outline>
          <outline text="Motion to suppress derivative evidence">
          </outline>
        </outline>
        <outline text="Prosecutorial Misconduct">
          <outline text="False representations of DNA &apos;matches&apos;">
          </outline>
          <outline text="Claim of &apos;major vaginal damage&apos; vs. records">
          </outline>
          <outline text="Omission of acquittal from official filings">
          </outline>
        </outline>
        <outline text="Jury Verdict (July 2023)">
          <outline text="Unanimous 12-0 acquittal on 1st Degree Rape">
          </outline>
          <outline text="9-3 split on 2nd Degree (majority acquittal)">
          </outline>
        </outline>
      </outline>
    </outline>
  </body>
